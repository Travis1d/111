  const tags=pick(C.hashtags,4+Math.floor(Math.random()*3)).join(" ");
  const structs=[
    `${res}\n\n发现了「兰慕女装 Lamooner」之后真的太不一样了 ${e1}\n${pts[0]}，${pts[1]}。\n${price}！\n\n${cta} ${e2}`,

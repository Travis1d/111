  ];
  return{hook:`✨ ${hook}`,body:pick(structs,1),tags};
}
function generateCopy(){
  genCount++;
  document.getElementById("gen-count").textContent=`第 ${genCount} 次生成`;
  const hEl=document.getElementById("copy-hook"),bEl=document.getElementById("copy-body"),tEl=document.getElementById("copy-tags");
  hEl.style.opacity=bEl.style.opacity=tEl.style.opacity="0";
  setTimeout(()=>{
    const{hook,body,tags}=buildCopy();
    hEl.textContent=hook;bEl.textContent=body;tEl.textContent=tags;
    hEl.style.transition=bEl.style.transition=tEl.style.transition="opacity .28s";
    hEl.style.opacity=bEl.style.opacity=tEl.style.opacity="1";
  },140);
}
function copyCopy(){
  const h=document.getElementById("copy-hook").textContent,b=document.getElementById("copy-body").textContent,t=document.getElementById("copy-tags").textContent;
  writeClipboard(`${h}\n\n${b}\n\n${t}`,"文案已复制！去小红书发帖吧 ✨");
}
let usedIndices=[];
function shufflePhotos(){
  const total=CONFIG.photos.length;
  let pool=[...Array(total).keys()].filter(i=>!usedIndices.includes(i));
  if(pool.length<3){pool=[...Array(total).keys()];usedIndices=[];}
  const chosen=pick(pool,3);
  usedIndices=Array.isArray(chosen)?chosen:[chosen];
  const list=document.getElementById("photo-list");
  list.innerHTML="";
  usedIndices.forEach((imgIdx,pos)=>{
    const item=document.createElement("div");
    item.className="photo-item";
    const img=document.createElement("img");
    img.src=CONFIG.photos[imgIdx];
    img.alt=`兰慕女装配图 ${pos+1}`;
    const badge=document.createElement("div");
    badge.className="photo-badge";
    badge.textContent=`图 ${pos+1} · 长按保存`;
    item.appendChild(img);item.appendChild(badge);list.appendChild(item);
    img.onload=()=>{item.style.minHeight="";}
  });
}
function copyWechat(){writeClipboard(CONFIG.wechatId,"微信号已复制！打开微信搜索添加 💬");}
function openXhs(e){
  e.preventDefault();showToast("正在跳转到兰慕小红书～ 📖");
  setTimeout(()=>{window.open(CONFIG.xhsUrl,"_blank","noopener");},380);return false;
}
function writeClipboard(text,msg){
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(text).then(()=>showToast("✅ "+msg)).catch(()=>fallback(text,msg));}
  else{fallback(text,msg);}
}
function fallback(text,msg){
  const ta=document.createElement("textarea");ta.value=text;ta.style.cssText="position:fixed;opacity:0;pointer-events:none;";
  document.body.appendChild(ta);ta.select();
  try{document.execCommand("copy");showToast("✅ "+msg);}catch{showToast("⚠️ 请手动长按复制");}
  document.body.removeChild(ta);
}
let toastTimer;
function showToast(msg){
  const t=document.getElementById("toast");t.textContent=msg;t.classList.add("show");
  clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove("show"),2600);
}
(function(){shufflePhotos();generateCopy();})();
</script>
